DATABASE_URL=sqlite:///./za_company.db
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=480

ADMIN_EMAIL=admin@za-company.com
ADMIN_PASSWORD=change-me

# Comma-separated frontend origins allowed to call this API. "*" (default) is fine for local dev.
# In production, set to your Vercel URL, e.g. https://za-company.vercel.app
CORS_ORIGINS=*
